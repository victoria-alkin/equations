{
  "functions": {
    "api/send-welcome.js": {
      "includeFiles": "email/WelcomeEmail.html"
    }
  },
  "headers": [
    {
      "source": "/(|daily|timed|battle|leagues|how-to-play|contact)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ],
  "rewrites": [
    { "source": "/invite/:id", "destination": "/api/invite/:id" },
    { "source": "/league-invite/:code", "destination": "/api/league-invite/:code" },
    { "source": "/leagues/:slug", "destination": "/api/leagues/:slug" },
    { "source": "/daily", "destination": "/index.html" },
    { "source": "/timed", "destination": "/index.html" },
    { "source": "/battle", "destination": "/index.html" },
    { "source": "/leagues", "destination": "/index.html" },
    { "source": "/how-to-play", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" }
  ]
}
